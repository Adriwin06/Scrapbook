{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Configure (Debug)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--preset",
        "debug-msvc"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Build + Deploy (Debug)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/Run-Scrapbook.ps1",
        "-Configuration",
        "Debug",
        "-NoRun"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$msCompile"
      ]
    },
    {
      "label": "Build + Deploy (Release)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/Run-Scrapbook.ps1",
        "-Configuration",
        "Release",
        "-NoRun"
      ],
      "problemMatcher": [
        "$msCompile"
      ]
    },
    {
      "label": "Launch via Script",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/Run-Scrapbook.ps1",
        "-Configuration",
        "Debug"
      ],
      "problemMatcher": []
    },
    {
      "label": "Package (Release)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/Package-Scrapbook.ps1",
        "-Configuration",
        "Release"
      ],
      "problemMatcher": []
    }
  ]
}
